# NextWiki Docker Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# DATA STORAGE CONFIGURATION
# =============================================================================
# Path where all data will be stored (can be absolute or relative)
# This includes PostgreSQL data, backups, and application data
# Change this to your preferred backup location
DATA_PATH=./data

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_NAME=nextwiki
DB_USER=nextwiki
DB_PASSWORD=nextwiki_password_change_this
DB_PORT=5432

# =============================================================================
# APPLICATION PORTS
# =============================================================================
WEB_PORT=3000
BACKEND_PORT=3001

# =============================================================================
# NEXTAUTH CONFIGURATION
# =============================================================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-character-secret-key-goes-here-change-this

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# OPTIONAL: WEBSOCKET BACKEND
# =============================================================================
# Only needed if you want real-time collaboration features
# Leave empty to disable backend service
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# =============================================================================
# PRODUCTION DEPLOYMENT SETTINGS
# =============================================================================
# Set this to your production domain when deploying
# NEXTAUTH_URL=https://your-domain.com
# NEXT_PUBLIC_WS_URL=wss://your-domain.com/ws